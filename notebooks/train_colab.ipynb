   "source": [
    "# MoP+DivPO — SFT Training (Google Colab)\n",
    "\n",
    "Trains one LoRA adapter per persona on a T4 GPU (~15 min per persona at 200 steps).\n",
    "\n",
    "**Before running:** make sure the SFT data has been pushed to HuggingFace Hub:\n",
    "```bash\n",
    "# Run locally first\n",
    "python -m mop_divpo.training.push_data\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1. Check GPU\n",
    "import torch\n",
    "print('CUDA available:', torch.cuda.is_available())\n",
    "if torch.cuda.is_available():\n",
    "    print('GPU:', torch.cuda.get_device_name(0))\n",
    "    print('VRAM:', round(torch.cuda.get_device_properties(0).total_memory / 1e9, 1), 'GB')"
   ]
  },
