   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4. HuggingFace login (needed to push trained adapters)\n",
    "from huggingface_hub import login\n",
    "login()  # paste your HF token when prompted"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 5. Load SFT data from HuggingFace Hub and save locally\n",
    "from datasets import load_dataset\n",
    "from pathlib import Path\n",
    "import json\n",
    "\n",
    "HF_DATASET = 'DasonTio/mop-divpo-sft-data'\n",
    "DATA_DIR = Path('data/processed/sft')\n",
    "DATA_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "ds = load_dataset(HF_DATASET)\n",
    "for persona, split in ds.items():\n",
    "    out = DATA_DIR / f'{persona}.jsonl'\n",
    "    with out.open('w') as f:\n",
    "        for row in split:\n",
    "            f.write(json.dumps(row) + '\\n')\n",
    "    print(f'{persona}: {len(split)} records -> {out}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 6. Train all personas — pushes adapters to HF Hub after each\n",
    "from pathlib import Path\n",
    "from mop_divpo.training.train_sft import train\n",
    "from mop_divpo.personas import PERSONA_IDS\n",
    "\n",
    "MAX_STEPS = 200\n",
    "\n",
    "for persona in PERSONA_IDS:\n",
    "    data_path = Path(f'data/processed/sft/{persona}.jsonl')\n",
    "    if not data_path.exists():\n",
    "        print(f'Skipping {persona}: data not found')\n",
    "        continue\n",
    "    print(f'\\n=== Training {persona} ===')\n",
    "    train(\n",
    "        persona_name=persona,\n",
    "        data_path=data_path,\n",
    "        output_dir=Path(f'outputs/adapters/sft/{persona}'),\n",
    "        max_steps=MAX_STEPS,\n",
    "        per_device_batch_size=4,\n",
    "        gradient_accumulation_steps=2,\n",
    "        push_to_hub=True,\n",
    "    )\n",
    "    print(f'Done: {persona}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 7. (Optional) Quick smoke-test — load adapter and generate\n",
    "from peft import PeftModel\n",
    "from transformers import AutoModelForCausalLM, AutoTokenizer\n",
    "import torch\n",
    "\n",
    "BASE_MODEL = 'Qwen/Qwen2.5-0.5B-Instruct'\n",
    "PERSONA = 'contrarian'\n",
    "ADAPTER_REPO = f'DasonTio/mop-divpo-{PERSONA}-sft'\n",
    "\n",
    "tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL)\n",
    "model = AutoModelForCausalLM.from_pretrained(BASE_MODEL, torch_dtype=torch.float16, device_map='auto')\n",
    "model = PeftModel.from_pretrained(model, ADAPTER_REPO)\n",
    "model.eval()\n",
    "\n",
    "prompt = 'What is the future of remote work?'\n",
    "messages = [\n",
    "    {'role': 'system', 'content': 'Challenges assumptions, surfaces minority dissent, and reframes common viewpoints.'},\n",
    "    {'role': 'user', 'content': prompt},\n",
    "]\n",
    "text = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n",
    "inputs = tokenizer(text, return_tensors='pt').to(model.device)\n",
    "with torch.no_grad():\n",
    "    out = model.generate(**inputs, max_new_tokens=200, do_sample=True, temperature=0.8)\n",
    "response = tokenizer.decode(out[0][inputs['input_ids'].shape[1]:], skip_special_tokens=True)\n",
    "print(f'[{PERSONA}]', response)"
   ]
  }
 ]
}"
